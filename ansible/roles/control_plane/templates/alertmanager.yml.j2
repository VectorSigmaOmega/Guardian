route:
  receiver: slack-notifications
  group_by:
    - alertname
    - instance
  group_wait: 10s
  group_interval: 1m
  repeat_interval: 2h
  routes:
    - receiver: remediation-webhook
      matchers:
        - auto_remediable="true"
      continue: true
    - receiver: slack-notifications

receivers:
  - name: slack-notifications
    slack_configs:
      - api_url: "{{ lookup('ansible.builtin.env', 'SLACK_WEBHOOK_URL') }}"
        channel: "{{ lookup('ansible.builtin.env', 'SLACK_CHANNEL') }}"
        send_resolved: true
        title: "[{{ '{{' }} .Status | toUpper {{ '}}' }}] {{ '{{' }} .CommonLabels.alertname {{ '}}' }}"
        text: >-
          {{ '{{' }} range .Alerts -{{ '}}' }}
          *Instance:* {{ '{{' }} .Labels.instance {{ '}}' }}
          *Summary:* {{ '{{' }} .Annotations.summary {{ '}}' }}
          *Description:* {{ '{{' }} .Annotations.description {{ '}}' }}

          {{ '{{' }} end {{ '}}' }}

  - name: remediation-webhook
    webhook_configs:
      - url: http://webhook:5000/remediate/internal
        send_resolved: false
        http_config:
          authorization:
            type: Bearer
            credentials: "{{ lookup('ansible.builtin.env', 'WEBHOOK_INTERNAL_TOKEN') }}"
