{% if groups.get('monitored_fleet', []) | length == 0 %}
[]
{% else %}
{% for host in groups.get('monitored_fleet', []) %}
- targets:
    - "{{ hostvars[host].ansible_host | default(host) }}:{{ hostvars[host].node_exporter_port | default(9100) }}"
  labels:
    host: "{{ host }}"
    role: "{{ hostvars[host].guardian_role | default('workload') }}"
{% endfor %}
{% endif %}
