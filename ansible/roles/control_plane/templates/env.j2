SLACK_WEBHOOK_URL={{ lookup('ansible.builtin.env', 'SLACK_WEBHOOK_URL') }}
SLACK_CHANNEL="{{ lookup('ansible.builtin.env', 'SLACK_CHANNEL') | default('#guardian-alerts', true) }}"
GRAFANA_ADMIN_PASSWORD={{ lookup('ansible.builtin.env', 'GRAFANA_ADMIN_PASSWORD') }}
WEBHOOK_INTERNAL_TOKEN={{ lookup('ansible.builtin.env', 'WEBHOOK_INTERNAL_TOKEN') }}
GUARDIAN_HMAC_SECRET={{ lookup('ansible.builtin.env', 'GUARDIAN_HMAC_SECRET') }}
GRAFANA_HOST={{ lookup('ansible.builtin.env', 'GRAFANA_HOST') }}
WEBHOOK_HOST={{ lookup('ansible.builtin.env', 'WEBHOOK_HOST') }}
{% for host in groups['monitored_fleet'] | default([]) %}
{% if hostvars[host].guardian_role | default('') == 'drill' %}
GUARDIAN_DRILL_HOST={{ hostvars[host].ansible_host | default(host) }}
GUARDIAN_DRILL_SSH_USER={{ hostvars[host].ansible_user | default('guardian') }}
{% endif %}
{% endfor %}
